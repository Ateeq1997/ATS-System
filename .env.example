# Google Gemini API key used for AI resume analysis.
# Get one at https://aistudio.google.com/app/apikey
# If omitted, the app falls back to a heuristic (non-AI) analysis.
GEMINI_API_KEY=

# Optional: override the Gemini model name.
GEMINI_MODEL=gemini-1.5-flash

# Comma-separated list of allowed CORS origins for the API.
# Use "*" for local development.
CORS_ORIGINS=*

# Base URL the frontend uses to call the API.
# - Single-domain deploy (Vercel, both frontend+backend on one domain): "/api"
# - Split deploy (e.g. Cloudflare Pages frontend + Render backend, different
#   domains): the full backend URL including /api, e.g.
#   https://ats-system-api.onrender.com/api
VITE_API_BASE_URL=/api
